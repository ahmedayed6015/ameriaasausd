{
  "entities": {
    "Page": {
      "title": "Landing Page",
      "description": "Configuration for a specific landing page",
      "type": "object",
      "properties": {
        "slug": { "type": "string", "description": "Unique long URL slug" },
        "title": { "type": "string", "description": "Page title" },
        "prize": { "type": "string", "description": "Prize amount" },
        "image": { "type": "string", "description": "Profile/Brand image URL" },
        "theme": {
          "type": "object",
          "properties": {
            "bg": { "type": "string" },
            "primary": { "type": "string" },
            "secondary": { "type": "string" },
            "text": { "type": "string" },
            "isDark": { "type": "boolean" }
          }
        },
        "redirectUrl": { "type": "string", "description": "Specific redirect URL for this page" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["slug", "prize", "image", "theme"]
    },
    "Settings": {
      "title": "Global Settings",
      "description": "Global configuration for all pages",
      "type": "object",
      "properties": {
        "globalRedirectUrl": { "type": "string" },
        "globalAdCode": { "type": "string" },
        "adminPassword": { "type": "string" }
      }
    }
  },
  "firestore": {
    "/pages/{pageId}": {
      "schema": "Page",
      "description": "Collection of landing pages"
    },
    "/settings/config": {
      "schema": "Settings",
      "description": "Global settings document"
    }
  }
}
